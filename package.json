    "check:source": "tsx scripts/check-source-changes.ts",
    "changelog": "tsx scripts/generate-changelog.ts",
    "extract:citations": "tsx scripts/extract-citations.ts",
    "ingest:citations": "tsx scripts/ingest-citations.ts",
    "multi:scenario": "tsx scripts/run-multi-scenario.ts",
    "checklist": "tsx scripts/generate-checklist.ts",
    "risk": "tsx scripts/generate-risk.ts",
    "heatmap": "tsx scripts/generate-heatmap.ts",
    "similarity": "tsx scripts/generate-similarity.ts",
    "trends": "tsx scripts/generate-trends.ts",
    "forecast": "tsx scripts/generate-forecast.ts",
    "report": "tsx scripts/generate-report.ts",
    "sdk": "tsx scripts/generate-sdk.ts",
